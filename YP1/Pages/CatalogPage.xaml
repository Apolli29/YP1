<UserControl x:Class="YP1.Pages.CatalogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="10"
                Background="#F8F8F8"
                BorderBrush="#C0C0C0"
                BorderThickness="1">
            <WrapPanel>
                <TextBox x:Name="SearchTextBox"
                         Width="220"
                         Margin="0,0,10,0"
                         Style="{StaticResource TextBoxStyle}" />

                <ComboBox x:Name="SortComboBox"
                          Width="130"
                          Style="{StaticResource FilterComboBoxStyle}">
                    <ComboBoxItem IsSelected="True" Tag="name">По имени</ComboBoxItem>
                    <ComboBoxItem Tag="rating">По оценке</ComboBoxItem>
                </ComboBox>

                <ComboBox x:Name="GenreComboBox"
                          Width="150"
                          DisplayMemberPath="Name"
                          SelectedValuePath="GenreId"
                          Style="{StaticResource FilterComboBoxStyle}" />

                <Button Width="100"
                        Margin="0,0,10,0"
                        Click="SearchButton_Click"
                        Style="{StaticResource AuthActionButtonStyle}"
                        Content="Найти" />

                <Button Width="100"
                        Click="ResetButton_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="Сброс" />
            </WrapPanel>
        </Border>

        <TextBlock x:Name="SummaryTextBlock"
                   Grid.Row="1"
                   Margin="0,10,0,10"
                   FontWeight="Bold" />

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BooksItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="250"
                                Margin="0,0,12,12"
                                Padding="10"
                                BorderBrush="#BFBFBF"
                                BorderThickness="1"
                                Background="White">
                            <StackPanel>
                                <Border Height="90"
                                        Margin="0,0,0,10"
                                        Background="{Binding CoverColor}"
                                        BorderBrush="#A0A0A0"
                                        BorderThickness="1">
                                    <TextBlock Margin="8"
                                               VerticalAlignment="Bottom"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Text="{Binding Title}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <TextBlock FontWeight="Bold"
                                           Text="{Binding Title}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding AuthorName}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding GenresText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding AverageRating, StringFormat=Рейтинг: {0:F1}}" />
                                <TextBlock Margin="0,6,0,0"
                                           MaxHeight="55"
                                           Text="{Binding Description}"
                                           TextWrapping="Wrap" />

                                <TextBlock x:Name="FrozenTextBlock"
                                           Margin="0,6,0,0"
                                           Foreground="DarkRed"
                                           FontWeight="Bold"
                                           Visibility="Collapsed"
                                           Text="Книга заморожена" />

                                <ComboBox Margin="0,8,0,8"
                                          SelectedValue="{Binding ListName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          Style="{StaticResource FilterComboBoxStyle}">
                                    <ComboBoxItem Tag="planned">В планах</ComboBoxItem>
                                    <ComboBoxItem Tag="reading">Читаю</ComboBoxItem>
                                    <ComboBoxItem Tag="completed">Прочитано</ComboBoxItem>
                                    <ComboBoxItem Tag="abandoned">Заброшено</ComboBoxItem>
                                </ComboBox>

                                <WrapPanel>
                                    <Button Width="100"
                                            Margin="0,0,10,0"
                                            Click="OpenBookButton_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="Открыть" />
                                    <Button Width="100"
                                            Click="AddToListButton_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"
                                            Content="В список" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsFrozen}" Value="True">
                                <Setter TargetName="FrozenTextBlock" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
