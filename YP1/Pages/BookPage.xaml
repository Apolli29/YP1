<UserControl x:Class="YP1.Pages.BookPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <Button Width="100"
                    HorizontalAlignment="Left"
                    Click="BackButton_Click"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Назад" />

            <Border Margin="0,12,0,0"
                    Padding="12"
                    Background="White"
                    BorderBrush="#C0C0C0"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="CoverBorder"
                            Width="160"
                            Height="220"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#5E6C84"
                            BorderBrush="#A0A0A0"
                            BorderThickness="1">
                        <TextBlock x:Name="CoverTitleTextBlock"
                                   Margin="10"
                                   VerticalAlignment="Bottom"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextWrapping="Wrap" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0">
                        <TextBlock x:Name="BookTitleTextBlock"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="BookAuthorTextBlock"
                                   Margin="0,8,0,0" />
                        <TextBlock x:Name="BookGenresTextBlock"
                                   Margin="0,5,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="BookRatingTextBlock"
                                   Margin="0,5,0,0" />

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="Bold"
                                   Text="Описание" />
                        <TextBlock x:Name="BookDescriptionTextBlock"
                                   TextWrapping="Wrap" />

                        <Border x:Name="FrozenInfoBorder"
                                Margin="0,10,0,0"
                                Padding="8"
                                Visibility="Collapsed"
                                Background="#FFF4D6"
                                BorderBrush="#D8B96B"
                                BorderThickness="1">
                            <TextBlock x:Name="FrozenInfoTextBlock"
                                       FontWeight="Bold"
                                       Foreground="DarkRed"
                                       TextWrapping="Wrap" />
                        </Border>

                        <WrapPanel Margin="0,12,0,0">
                            <ComboBox x:Name="ListComboBox"
                                      Width="130"
                                      Margin="0,0,10,10"
                                      SelectedValuePath="Tag"
                                      Style="{StaticResource FilterComboBoxStyle}">
                                <ComboBoxItem IsSelected="True" Tag="planned">В планах</ComboBoxItem>
                                <ComboBoxItem Tag="reading">Читаю</ComboBoxItem>
                                <ComboBoxItem Tag="completed">Прочитано</ComboBoxItem>
                                <ComboBoxItem Tag="abandoned">Заброшено</ComboBoxItem>
                            </ComboBox>

                            <Button Width="110"
                                    Margin="0,0,10,10"
                                    Click="AddToListButton_Click"
                                    Style="{StaticResource AuthActionButtonStyle}"
                                    Content="В список" />

                            <Button Width="110"
                                    Margin="0,0,10,10"
                                    Click="ReportBookButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Жалоба" />

                            <Button Width="150"
                                    Margin="0,0,0,10"
                                    Click="ReportAuthorButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Жалоба на автора" />
                        </WrapPanel>

                        <Button x:Name="FreezeBookButton"
                                Width="150"
                                HorizontalAlignment="Left"
                                Visibility="Collapsed"
                                Click="FreezeBookButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Заморозить книгу" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Margin="0,12,0,0"
                    Padding="12"
                    Background="White"
                    BorderBrush="#C0C0C0"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock FontWeight="Bold"
                               Text="Текст книги" />
                    <TextBox x:Name="BookTextTextBox"
                             Margin="0,8,0,0"
                             Height="220"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource MultilineTextBoxStyle}" />
                </StackPanel>
            </Border>

            <Border Margin="0,12,0,0"
                    Padding="12"
                    Background="White"
                    BorderBrush="#C0C0C0"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock FontWeight="Bold"
                               Text="Оставить отзыв" />
                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock Margin="0,6,10,0"
                                   Text="Оценка" />
                        <ComboBox x:Name="ReviewRatingComboBox"
                                  Width="90"
                                  SelectedValuePath="Tag"
                                  Style="{StaticResource FilterComboBoxStyle}">
                            <ComboBoxItem IsSelected="True" Tag="5">5</ComboBoxItem>
                            <ComboBoxItem Tag="4">4</ComboBoxItem>
                            <ComboBoxItem Tag="3">3</ComboBoxItem>
                            <ComboBoxItem Tag="2">2</ComboBoxItem>
                            <ComboBoxItem Tag="1">1</ComboBoxItem>
                        </ComboBox>
                    </WrapPanel>

                    <TextBox x:Name="ReviewTextBox"
                             Margin="0,8,0,0"
                             Height="90"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource MultilineTextBoxStyle}" />

                    <Button Width="140"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Click="SaveReviewButton_Click"
                            Style="{StaticResource AuthActionButtonStyle}"
                            Content="Сохранить отзыв" />
                </StackPanel>
            </Border>

            <StackPanel Margin="0,12,0,0">
                <TextBlock FontSize="18"
                           FontWeight="Bold"
                           Text="Отзывы" />

                <ItemsControl x:Name="ReviewsItemsControl"
                              Margin="0,10,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="10"
                                    Background="White"
                                    BorderBrush="#C0C0C0"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontWeight="Bold"
                                               Text="{Binding UserName}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding Rating, StringFormat=Оценка: {0}/5}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding ReviewText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="DarkRed"
                                               Text="{Binding FreezeReason}"
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Width="110"
                                                Margin="0,0,10,0"
                                                Click="ReportReviewButton_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Жалоба" />
                                        <Button x:Name="FreezeReviewButton"
                                                Width="150"
                                                Visibility="Collapsed"
                                                Click="FreezeReviewButton_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Заморозить отзыв" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding CanAdminFreeze}" Value="True">
                                    <Setter TargetName="FreezeReviewButton" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
