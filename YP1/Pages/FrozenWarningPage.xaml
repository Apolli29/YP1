<UserControl x:Class="YP1.Pages.FrozenWarningPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <Border Padding="24"
                Background="White"
                CornerRadius="22">
            <StackPanel>
                <TextBlock FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           Text="Предупреждение о заморозке" />

                <Border x:Name="WarningBorder"
                        Margin="0,22,0,0"
                        Padding="18"
                        Background="#FBE4DC"
                        CornerRadius="18">
                    <TextBlock x:Name="WarningTextBlock"
                               Foreground="{StaticResource AccentBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock x:Name="HintTextBlock"
                           Margin="0,18,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap" />

                <Button x:Name="AppealFreezeButton"
                        Width="220"
                        Margin="0,24,0,0"
                        HorizontalAlignment="Left"
                        Click="AppealFreezeButton_Click"
                        Style="{StaticResource AuthActionButtonStyle}"
                        Content="Оспорить заморозку" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
