<UserControl x:Class="YP1.Pages.FrozenWarningPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Border Padding="16"
                Background="White"
                BorderBrush="#C0C0C0"
                BorderThickness="1">
            <StackPanel>
                <TextBlock FontSize="22"
                           FontWeight="Bold"
                           Text="Предупреждение о заморозке" />

                <Border x:Name="WarningBorder"
                        Margin="0,14,0,0"
                        Padding="12"
                        Background="#FFF4D6"
                        BorderBrush="#D8B96B"
                        BorderThickness="1">
                    <TextBlock x:Name="WarningTextBlock"
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock x:Name="HintTextBlock"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap" />

                <Button x:Name="AppealFreezeButton"
                        Width="190"
                        Margin="0,16,0,0"
                        HorizontalAlignment="Left"
                        Click="AppealFreezeButton_Click"
                        Style="{StaticResource AuthActionButtonStyle}"
                        Content="Оспорить заморозку" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
