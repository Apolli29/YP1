<UserControl x:Class="YP1.Pages.ProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="20"
                    Background="White"
                    CornerRadius="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Информация о пользователе" />
                        <TextBlock x:Name="FullNameTextBlock"
                                   Margin="0,18,0,0"
                                   FontSize="18"
                                   Foreground="{StaticResource PrimaryTextBrush}" />
                        <TextBlock x:Name="LoginTextBlock"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock x:Name="EmailTextBlock"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock x:Name="RoleTextBlock"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Действия" />
                        <Button x:Name="AuthorRequestButton"
                                Margin="0,18,0,12"
                                Click="AuthorRequestButton_Click"
                                Style="{StaticResource AuthActionButtonStyle}"
                                Content="Стать автором" />
                        <Button x:Name="AppealButton"
                                Click="AppealButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Оспорить заморозку" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="FreezeInfoBorder"
                    Grid.Row="1"
                    Margin="0,20,0,0"
                    Padding="18"
                    Visibility="Collapsed"
                    Background="#FBE4DC"
                    CornerRadius="18">
                <StackPanel>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               Text="Аккаунт заморожен" />
                    <TextBlock x:Name="FreezeReasonTextBlock"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource AccentBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2"
                       Margin="0,22,0,14"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       Text="Мои отзывы" />

            <ItemsControl x:Name="ReviewsItemsControl"
                          Grid.Row="3">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,14"
                                Padding="16"
                                Background="White"
                                CornerRadius="18">
                            <StackPanel>
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           Text="{Binding BookTitle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Text="{Binding Rating, StringFormat=оценка: {0}/5}" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           Text="{Binding ReviewText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
