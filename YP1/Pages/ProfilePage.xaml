<UserControl x:Class="YP1.Pages.ProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="12"
                    Background="White"
                    BorderBrush="#BFBFBF"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="20"
                                   FontWeight="Bold"
                                   Text="Данные пользователя" />
                        <TextBlock x:Name="FullNameTextBlock"
                                   Margin="0,12,0,0"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="LoginTextBlock"
                                   Margin="0,6,0,0" />
                        <TextBlock x:Name="EmailTextBlock"
                                   Margin="0,6,0,0" />
                        <TextBlock x:Name="RoleTextBlock"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Button x:Name="AuthorRequestButton"
                                Margin="0,0,0,10"
                                Click="AuthorRequestButton_Click"
                                Style="{StaticResource AuthActionButtonStyle}"
                                Content="Стать автором" />
                        <Button x:Name="AppealButton"
                                Click="AppealButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Оспорить заморозку" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="FreezeInfoBorder"
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    Visibility="Collapsed"
                    Background="#FFF4D6"
                    BorderBrush="#D8B96B"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock FontWeight="Bold"
                               Text="Аккаунт заморожен" />
                    <TextBlock x:Name="FreezeReasonTextBlock"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2"
                       Margin="0,14,0,10"
                       FontSize="18"
                       FontWeight="Bold"
                       Text="Мои отзывы" />

            <ItemsControl x:Name="ReviewsItemsControl"
                          Grid.Row="3">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10"
                                Padding="10"
                                Background="White"
                                BorderBrush="#BFBFBF"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontWeight="Bold"
                                           Text="{Binding BookTitle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding Rating, StringFormat=Оценка: {0}/5}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding ReviewText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="Gray"
                                           Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
