<UserControl x:Class="YP1.Pages.AuthorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="22"
                           FontWeight="Bold"
                           Text="Книги автора" />
                <Button Width="150"
                        HorizontalAlignment="Right"
                        Click="AddBookButton_Click"
                        Style="{StaticResource AuthActionButtonStyle}"
                        Content="Добавить книгу" />
            </DockPanel>

            <TextBlock Margin="0,16,0,8"
                       FontSize="18"
                       FontWeight="Bold"
                       Text="Опубликованные книги" />

            <ItemsControl x:Name="AuthorBooksItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10"
                                Padding="10"
                                Background="White"
                                BorderBrush="#C0C0C0"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="130" />
                                </Grid.ColumnDefinitions>

                                <Border Width="80"
                                        Height="110"
                                        Background="{Binding CoverColor}"
                                        BorderBrush="#A0A0A0"
                                        BorderThickness="1">
                                    <TextBlock Margin="8"
                                               VerticalAlignment="Bottom"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Text="{Binding Title}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="10,0,10,0">
                                    <TextBlock FontSize="16"
                                               FontWeight="Bold"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding GenresText}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding AverageRating, StringFormat=рейтинг: {0:F1}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding Description}"
                                               TextWrapping="Wrap"
                                               MaxHeight="60" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Top">
                                    <Button Width="120"
                                            Margin="0,0,0,8"
                                            Click="OpenBookButton_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="Открыть" />
                                    <Button Width="120"
                                            Click="EditBookButton_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"
                                            Content="Изменить" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Margin="0,18,0,8"
                       FontSize="18"
                       FontWeight="Bold"
                       Text="Замороженные книги" />

            <ItemsControl x:Name="FrozenBooksItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10"
                                Padding="10"
                                Background="White"
                                BorderBrush="#C0C0C0"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="Bold"
                                           Text="{Binding Title}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="DarkRed"
                                           Text="{Binding FreezeReason}"
                                           TextWrapping="Wrap" />
                                <WrapPanel Margin="0,8,0,0">
                                    <Button Width="140"
                                            Margin="0,0,10,0"
                                            Click="EditBookButton_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="Исправить книгу" />
                                    <Button Width="170"
                                            Click="AppealFrozenBookButton_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"
                                            Content="Оспорить заморозку" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
