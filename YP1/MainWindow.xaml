<Window x:Class="YP1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай, Пиши и не спиши"
        Width="1200"
        Height="780"
        MinWidth="1000"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource SidebarBrush}"
                BorderBrush="Brown"
                BorderThickness="1">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Margin="0,0,0,14"
                           FontSize="18"
                           FontWeight="Bold"
                           Text="Меню" />

                <StackPanel Grid.Row="1">
                    <Button x:Name="CatalogButton"
                            Click="CatalogButton_Click"
                            Style="{StaticResource SidebarButtonStyle}"
                            Content="Каталог книг" />

                    <Button x:Name="ListsButton"
                            Click="ListsButton_Click"
                            Style="{StaticResource SidebarButtonStyle}"
                            Content="Списки книг" />

                    <Button x:Name="AdminButton"
                            Click="AdminButton_Click"
                            Style="{StaticResource SidebarButtonStyle}"
                            Content="Администрирование" />

                    <Button x:Name="AuthorButton"
                            Click="AuthorButton_Click"
                            Style="{StaticResource SidebarButtonStyle}"
                            Content="Страница автора" />

                    <Button x:Name="FrozenButton"
                            Click="FrozenButton_Click"
                            Style="{StaticResource SidebarButtonStyle}"
                            Content="Предупреждение" />

                    <Button x:Name="ProfileButton"
                            Click="ProfileButton_Click"
                            Style="{StaticResource SidebarButtonStyle}"
                            Content="Профиль" />
                </StackPanel>

                <Button x:Name="LogoutButton"
                        Grid.Row="2"
                        Click="LogoutButton_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="Выход" />
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="10"
                    Background="White"
                    BorderBrush="Brown"
                    BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock x:Name="PageTitleTextBlock"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Каталог книг" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Электронная библиотека" />
                    </StackPanel>

                    <TextBlock x:Name="CurrentUserTextBlock"
                               Margin="0,0,10,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,10,0,0"
                    Background="White"
                    BorderBrush="#B0B0B0"
                    BorderThickness="1">
                <ContentControl x:Name="PageHost" />
            </Border>
        </Grid>
    </Grid>
</Window>
