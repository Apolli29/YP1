<Window x:Class="YP1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай, Пиши и не спиши"
        Width="1200"
        Height="780"
        MinWidth="1000"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource SidebarBrush}"
                BorderBrush="#B0B0B0"
                BorderThickness="1">
            <DockPanel>
                <StackPanel Margin="0,10,0,10"
                            VerticalAlignment="Top">
                    <TextBlock Margin="0,0,0,14"
                               HorizontalAlignment="Center"
                               FontSize="18"
                               FontWeight="Bold"
                               Text="ЧП" />

                    <Button x:Name="CatalogButton"
                            ToolTip="Каталог книг"
                            Click="CatalogButton_Click"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Text="&#xE8D2;" />
                    </Button>

                    <Button x:Name="ListsButton"
                            ToolTip="Списки книг"
                            Click="ListsButton_Click"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Text="&#xE14C;" />
                    </Button>

                    <Button x:Name="AdminButton"
                            ToolTip="Администрирование"
                            Click="AdminButton_Click"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Text="&#xE713;" />
                    </Button>

                    <Button x:Name="AuthorButton"
                            ToolTip="Страница автора"
                            Click="AuthorButton_Click"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Text="&#xE8D3;" />
                    </Button>

                    <Button x:Name="FrozenButton"
                            ToolTip="Предупреждение о заморозке"
                            Click="FrozenButton_Click"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Text="&#xE7BA;" />
                    </Button>
                </StackPanel>

                <Button x:Name="ProfileButton"
                        Margin="0,0,0,10"
                        VerticalAlignment="Bottom"
                        ToolTip="Профиль"
                        Click="ProfileButton_Click"
                        Style="{StaticResource SidebarButtonStyle}">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="18"
                               Text="&#xE77B;" />
                </Button>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1"
              Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="10"
                    Background="White"
                    BorderBrush="#B0B0B0"
                    BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock x:Name="PageTitleTextBlock"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Каталог книг" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Электронная библиотека" />
                    </StackPanel>

                    <TextBlock x:Name="CurrentUserTextBlock"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,10,0,0"
                    Background="White"
                    BorderBrush="#B0B0B0"
                    BorderThickness="1">
                <ContentControl x:Name="PageHost" />
            </Border>
        </Grid>
    </Grid>
</Window>
