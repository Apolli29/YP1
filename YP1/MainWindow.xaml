<Window x:Class="YP1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай, Пиши и не спиши"
        Width="1380"
        Height="860"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Border Margin="20"
            CornerRadius="24"
            Background="White">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource SidebarBrush}"
                    CornerRadius="24,0,0,24">
                <DockPanel LastChildFill="True">
                    <StackPanel Margin="0,18,0,18"
                                VerticalAlignment="Top">
                        <TextBlock Margin="0,0,0,20"
                                   HorizontalAlignment="Center"
                                   FontSize="24"
                                   Foreground="White"
                                   Text="ЧП" />

                        <Button x:Name="CatalogButton"
                                ToolTip="Каталог книг"
                                Click="CatalogButton_Click"
                                Style="{StaticResource SidebarButtonStyle}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Text="&#xE8D2;" />
                        </Button>

                        <Button x:Name="ListsButton"
                                ToolTip="Списки книг"
                                Click="ListsButton_Click"
                                Style="{StaticResource SidebarButtonStyle}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Text="&#xE14C;" />
                        </Button>

                        <Button x:Name="AdminButton"
                                ToolTip="Администрирование"
                                Click="AdminButton_Click"
                                Style="{StaticResource SidebarButtonStyle}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Text="&#xE713;" />
                        </Button>

                        <Button x:Name="AuthorButton"
                                ToolTip="Страница автора"
                                Click="AuthorButton_Click"
                                Style="{StaticResource SidebarButtonStyle}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Text="&#xE8D3;" />
                        </Button>

                        <Button x:Name="FrozenButton"
                                ToolTip="Предупреждение о заморозке"
                                Click="FrozenButton_Click"
                                Style="{StaticResource SidebarButtonStyle}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Text="&#xE7BA;" />
                        </Button>
                    </StackPanel>

                    <Button x:Name="ProfileButton"
                            Margin="0,0,0,10"
                            VerticalAlignment="Bottom"
                            ToolTip="Профиль"
                            Click="ProfileButton_Click"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="22"
                                   Text="&#xE77B;" />
                    </Button>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="30,24,30,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="PageTitleTextBlock"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Каталог книг" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Учебный каркас приложения для библиотеки и чтения книг." />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="16,10"
                            Background="{StaticResource LightAccentBrush}"
                            CornerRadius="16">
                        <TextBlock x:Name="CurrentUserTextBlock"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="гость" />
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Margin="30,0,30,30"
                        CornerRadius="20"
                        Background="{StaticResource PanelBrush}">
                    <ContentControl x:Name="PageHost" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
