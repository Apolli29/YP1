<Window x:Class="YP1.Windows.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай, Пиши и не спиши"
        Width="960"
        Height="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="0.9*" />
        </Grid.ColumnDefinitions>

        <Border Margin="0,0,20,0"
                Padding="36"
                Background="{StaticResource SidebarBrush}"
                CornerRadius="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="14"
                               Foreground="#D9E3F0"
                               Text="учебная библиотека" />
                    <TextBlock Margin="0,14,0,0"
                               FontSize="38"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="Читай, Пиши и не спиши" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="Что будет внутри" />
                    <TextBlock Margin="0,18,0,0"
                               Foreground="#D9E3F0"
                               Text="• каталог книг с поиском и фильтрами" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#D9E3F0"
                               Text="• списки книг пользователя" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#D9E3F0"
                               Text="• страница автора и администрирование" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#D9E3F0"
                               Text="• отзывы, жалобы и заморозки" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Foreground="#D9E3F0"
                           Text="Каркас авторизации и главного окна уже готов." />
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Padding="26"
                Background="{StaticResource PanelBrush}"
                CornerRadius="28">
            <TabControl>
                <TabItem Header="Вход">
                    <StackPanel Margin="18">
                        <TextBlock FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Авторизация" />
                        <TextBlock Margin="0,8,0,24"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Пока что окно работает в демонстрационном режиме." />

                        <TextBlock Margin="0,0,0,6"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Логин" />
                        <TextBox x:Name="LoginTextBox"
                                 Style="{StaticResource TextBoxStyle}" />

                        <TextBlock Margin="0,0,0,6"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Пароль" />
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource PasswordBoxStyle}" />

                        <Button Margin="0,12,0,0"
                                Click="LoginButton_Click"
                                Style="{StaticResource AuthActionButtonStyle}"
                                Content="Войти" />
                    </StackPanel>
                </TabItem>

                <TabItem Header="Регистрация">
                    <StackPanel Margin="18">
                        <TextBlock FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Регистрация" />
                        <TextBlock Margin="0,8,0,24"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Позже сюда добавится запись нового пользователя в базу." />

                        <TextBlock Margin="0,0,0,6"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Имя" />
                        <TextBox x:Name="RegisterNameTextBox"
                                 Style="{StaticResource TextBoxStyle}" />

                        <TextBlock Margin="0,0,0,6"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Логин" />
                        <TextBox x:Name="RegisterLoginTextBox"
                                 Style="{StaticResource TextBoxStyle}" />

                        <TextBlock Margin="0,0,0,6"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Электронная почта" />
                        <TextBox x:Name="RegisterEmailTextBox"
                                 Style="{StaticResource TextBoxStyle}" />

                        <TextBlock Margin="0,0,0,6"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Пароль" />
                        <PasswordBox x:Name="RegisterPasswordBox"
                                     Style="{StaticResource PasswordBoxStyle}" />

                        <Button Margin="0,12,0,0"
                                Click="RegisterButton_Click"
                                Style="{StaticResource AuthActionButtonStyle}"
                                Content="Создать аккаунт" />
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
