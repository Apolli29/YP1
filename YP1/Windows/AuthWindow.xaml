<Window x:Class="YP1.Windows.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай, Пиши и не спиши"
        Width="760"
        Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="20">
        <Border Padding="16"
                Background="White"
                BorderBrush="#B0B0B0"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Text="Читай, Пиши и не спиши" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="Учебное приложение для чтения книг и отзывов" />
                </StackPanel>

                <Border x:Name="DatabaseWarningBorder"
                        Grid.Row="1"
                        Margin="0,16,0,12"
                        Padding="10"
                        Visibility="Collapsed"
                        Background="#FFF4D6"
                        BorderBrush="#D8B96B"
                        BorderThickness="1">
                    <TextBlock x:Name="DatabaseWarningTextBlock"
                               TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,16,0"
                            Padding="12"
                            Background="#F8F8F8"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="Bold"
                                       Text="Тестовые аккаунты" />
                            <TextBlock Margin="0,12,0,0"
                                       Text="admin / admin123" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="author1 / author123" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="reader1 / reader123" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="frozen1 / frozen123" />
                        </StackPanel>
                    </Border>

                    <TabControl Grid.Column="1">
                        <TabItem Header="Вход">
                            <StackPanel Margin="14">
                                <TextBlock Margin="0,0,0,4"
                                           Text="Логин" />
                                <TextBox x:Name="LoginTextBox"
                                         Style="{StaticResource TextBoxStyle}" />

                                <TextBlock Margin="0,0,0,4"
                                           Text="Пароль" />
                                <PasswordBox x:Name="PasswordBox"
                                             Style="{StaticResource PasswordBoxStyle}" />

                                <Button x:Name="LoginButton"
                                        Width="120"
                                        HorizontalAlignment="Left"
                                        Click="LoginButton_Click"
                                        Style="{StaticResource AuthActionButtonStyle}"
                                        Content="Войти" />
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Регистрация">
                            <StackPanel Margin="14">
                                <TextBlock Margin="0,0,0,4"
                                           Text="Имя" />
                                <TextBox x:Name="RegisterNameTextBox"
                                         Style="{StaticResource TextBoxStyle}" />

                                <TextBlock Margin="0,0,0,4"
                                           Text="Логин" />
                                <TextBox x:Name="RegisterLoginTextBox"
                                         Style="{StaticResource TextBoxStyle}" />

                                <TextBlock Margin="0,0,0,4"
                                           Text="Электронная почта" />
                                <TextBox x:Name="RegisterEmailTextBox"
                                         Style="{StaticResource TextBoxStyle}" />

                                <TextBlock Margin="0,0,0,4"
                                           Text="Пароль" />
                                <PasswordBox x:Name="RegisterPasswordBox"
                                             Style="{StaticResource PasswordBoxStyle}" />

                                <Button x:Name="RegisterButton"
                                        Width="160"
                                        HorizontalAlignment="Left"
                                        Click="RegisterButton_Click"
                                        Style="{StaticResource AuthActionButtonStyle}"
                                        Content="Зарегистрироваться" />
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
