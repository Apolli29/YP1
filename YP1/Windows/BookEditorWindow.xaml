<Window x:Class="YP1.Windows.BookEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книга"
        Width="700"
        Height="680"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}">
    <Border Margin="16"
            Padding="16"
            Background="White"
            BorderBrush="#C0C0C0"
            BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="HeaderTextBlock"
                           FontSize="22"
                           FontWeight="Bold" />

                <TextBlock Margin="0,14,0,4"
                           Text="Название" />
                <TextBox x:Name="TitleTextBox"
                         Style="{StaticResource TextBoxStyle}" />

                <TextBlock Margin="0,8,0,4"
                           Text="Описание" />
                <TextBox x:Name="DescriptionTextBox"
                         Height="100"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Style="{StaticResource MultilineTextBoxStyle}" />

                <TextBlock Margin="0,8,0,4"
                           Text="Текст книги" />
                <TextBox x:Name="BookTextTextBox"
                         Height="200"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Style="{StaticResource MultilineTextBoxStyle}" />

                <TextBlock Margin="0,8,0,4"
                           Text="Цвет обложки" />
                <TextBox x:Name="CoverColorTextBox"
                         Style="{StaticResource TextBoxStyle}" />

                <TextBlock Margin="0,8,0,8"
                           Text="Жанры" />
                <ItemsControl x:Name="GenresItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Margin="0,0,14,10"
                                      IsChecked="{Binding IsSelected}"
                                      Content="{Binding Name}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Margin="0,14,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button Width="110"
                            Margin="0,0,10,0"
                            Click="CancelButton_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Отмена" />
                    <Button Width="110"
                            Click="SaveButton_Click"
                            Style="{StaticResource AuthActionButtonStyle}"
                            Content="Сохранить" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
